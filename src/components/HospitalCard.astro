---
import { hospitalSlug, type Hospital } from '../lib/hospitals.js';
import { localizePath, detectLocale, deptLabel, type Locale } from '../lib/i18n';

interface Props {
  hospital: Hospital;
  locale?: Locale;
}

const { hospital: h, locale: localeProp } = Astro.props;
const locale: Locale = localeProp ?? detectLocale(Astro.url.pathname);
const slug = hospitalSlug(h);
const detailHref = localizePath(`/hospital/${encodeURIComponent(slug)}`, locale);

const langSet = new Set(h.langs || []);
const badges: { cls: string; label: string }[] = [];
if (langSet.has('中文')) badges.push({ cls: 'badge badge-cn', label: locale === 'zh' ? '中文' : 'CN' });
if (langSet.has('英文')) badges.push({ cls: 'badge badge-en', label: locale === 'zh' ? '英文' : 'EN' });
(h.extraBadges || []).forEach((b) => badges.push({ cls: 'badge badge-new', label: b.label }));

const updatedFmt = (() => {
  const m = (h.updated || '').match(/^(\d{4})-(\d{1,2})$/);
  if (!m) return h.updated || '';
  return locale === 'zh'
    ? `${m[1]}年${parseInt(m[2], 10)}月`
    : `${m[1]}-${m[2].padStart(2, '0')}`;
})();

const telDigits = (h.phone || '').replace(/[^\d+]/g, '');
const hasPhone = telDigits.length >= 9;

const mapAddr = h.address || h.addressShort;
const mapHref = mapAddr
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(h.name + ' ' + mapAddr)}`
  : null;

const langDataAttr = h.langDetail || (h.langs || []).join(' ');
// 数据属性给客户端搜索用：两种语言都放进去，搜索框输入英文中文都能匹配
const deptsDataAttr = (h.depts || []).flatMap((d) => {
  const en = deptLabel(d, 'en');
  return en === d ? [d] : [d, en];
}).join(' ');

const labels = locale === 'zh'
  ? { call: '电话', map: '地图', callAria: `拨打 ${h.name}`, mapAria: `在地图查看 ${h.name}` }
  : { call: 'Call', map: 'Map', callAria: `Call ${h.name}`, mapAria: `View ${h.name} on map` };
---
<article
  class="hospital-card fade-in"
  role="listitem"
  data-name={h.searchKeys || h.name}
  data-region={h.region || ''}
  data-lang={langDataAttr}
  data-depts={deptsDataAttr}
  data-updated={h.updated || ''}
>
  <a class="card-link" href={detailHref}>
    {h.region && (
      <div class="card-eyebrow">
        <span class="card-region">{h.region}</span>
      </div>
    )}
    <div class="card-row1">
      <div class="card-title">
        <div class="hospital-name">{h.name}</div>
        <div class="hospital-name-ja">{h.jpName || ''}</div>
      </div>
      <div class="badges">
        {badges.map(b => <span class={b.cls}>{b.label}</span>)}
      </div>
    </div>
    <div class="card-info">
      <div class="card-info-row">
        {h.addressShort && (
          <div class="info-item"><span class="info-icon">📍</span>{h.addressShort}</div>
        )}
        {h.warning ? (
          <div class="info-item"><span class="info-icon">⚠️</span>{h.warning}</div>
        ) : h.hoursShort && (
          <div class="info-item"><span class="info-icon">🕐</span>{h.hoursShort}</div>
        )}
      </div>
    </div>
    <div class="card-depts">
      {(h.depts || []).map((d) => <span class="dept-tag">{deptLabel(d, locale)}</span>)}
    </div>
  </a>
  <div class="card-footer">
    <span class="card-updated">{updatedFmt}</span>
    <div class="card-actions">
      {hasPhone && (
        <a class="card-action" href={`tel:${telDigits}`} aria-label={labels.callAria}>
          <span aria-hidden="true">📞</span>
          <span>{labels.call}</span>
        </a>
      )}
      {mapHref && (
        <a class="card-action" href={mapHref} target="_blank" rel="noopener noreferrer" aria-label={labels.mapAria}>
          <span aria-hidden="true">🗺</span>
          <span>{labels.map}</span>
        </a>
      )}
    </div>
  </div>
</article>
