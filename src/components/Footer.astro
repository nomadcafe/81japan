---
import { localizePath, detectLocale, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}
const { locale: localeProp } = Astro.props;
const locale: Locale = localeProp ?? detectLocale(Astro.url.pathname);
const year = new Date().getFullYear();
const submitHref = localizePath('/submit', locale);
---
<footer>
  <div>
    {locale === 'zh'
      ? <>© {year} 81日本 · 由 81Japan 维护</>
      : <>© {year} 81Japan · maintained by 81Japan</>
    }
  </div>
  <a href={submitHref}>{locale === 'zh' ? '联系我' : 'Contact'}</a>
</footer>
