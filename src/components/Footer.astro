---
import { localizePath, detectLocale, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}
const { locale: localeProp } = Astro.props;
const locale: Locale = localeProp ?? detectLocale(Astro.url.pathname);
const year = new Date().getFullYear();
---
<footer>
  <div>
    {locale === 'zh'
      ? <>© {year} 81日本 · 由 81Japan 维护</>
      : <>© {year} 81Japan · maintained by 81Japan</>
    }
  </div>
  <a class="contact-link" href="#" data-user="hello" data-domain="81japan.com">{locale === 'zh' ? '联系我' : 'Contact'}</a>
</footer>
<script>
  document.querySelectorAll<HTMLAnchorElement>('a.contact-link').forEach((a) => {
    const user = a.dataset.user;
    const domain = a.dataset.domain;
    if (user && domain) a.href = `mailto:${user}@${domain}`;
  });
</script>
