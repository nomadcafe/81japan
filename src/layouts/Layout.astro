---
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';
import { detectLocale, HTML_LANG, type Locale } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  twitterCard?: 'summary' | 'summary_large_image';
  bodyClass?: string;
  locale?: Locale;
}

const {
  title,
  description,
  path,
  image,
  imageAlt,
  noindex,
  twitterCard,
  bodyClass,
  locale: localeProp,
} = Astro.props;

const locale: Locale = localeProp ?? detectLocale(Astro.url.pathname);
const htmlLang = HTML_LANG[locale];
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO {title} {description} {path} {image} {imageAlt} {noindex} {twitterCard} {locale} />

  <link rel="icon" type="image/png" href="/81japan.png" />
  <link rel="apple-touch-icon" href="/81j.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&family=Noto+Sans+SC:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&family=Noto+Sans+SC:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&family=Noto+Sans+SC:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>

  <slot name="head" />

  <script is:inline>
    (function () {
      try {
        var path = location.pathname;
        var onEn = path === '/en' || path.indexOf('/en/') === 0;
        if (onEn) {
          localStorage.setItem('preferredLang', 'en');
          return;
        }
        var onRoot = path === '/' || path === '';
        var stored = localStorage.getItem('preferredLang');
        if (stored === 'en' && onRoot) {
          location.replace('/en');
          return;
        }
        if (!stored && onRoot) {
          var lang = (navigator.language || '').toLowerCase();
          if (lang.indexOf('en') === 0 && lang.indexOf('zh') === -1) {
            localStorage.setItem('preferredLang', 'en');
            location.replace('/en');
            return;
          }
          localStorage.setItem('preferredLang', 'zh');
        }
      } catch (e) {}
    })();
  </script>
</head>
<body class={bodyClass}>
  <slot />
  <Analytics />
</body>
</html>
