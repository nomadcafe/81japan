---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import rent from '../data/rent.json';
import '../styles/page.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      'name': '在日租房指南',
      'itemListElement': rent.map((r, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': r.titleZh,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': '首页', 'item': 'https://www.81japan.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': '租房' },
      ],
    },
  ],
};
---
<Layout
  title="租房 · 在日租房指南 | 81日本"
  description="在日租房必懂：敷金、礼金、仲介手数料、保証会社、入居审查、UR 物件等——外国人在日本找房子的关键信息。"
  path="/rent"
  locale="zh"
>
  <Fragment slot="head">
    <meta name="keywords" content="日本租房,敷金,礼金,仲介手数料,保証会社,入居審査,UR 物件,外国人租房日本" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="rent" locale="zh" />

  <section class="page-hero">
    <div class="eyebrow">租房</div>
    <h1>在日本找房子，<em>先搞懂规则</em></h1>
    <p>初期费用、保証会社、入居审查——日本租房的几个绕不开的概念。</p>
  </section>

  <main class="page-main">
    <div class="rules-grid">
      {rent.map((r) => (
        <article class="rule-card" id={r.id}>
          <div class="rule-card-head">
            <div class="rule-icon" aria-hidden="true">{r.icon}</div>
            <div>
              <div class="rule-title">{r.titleZh}</div>
              <div class="rule-title-en">{r.titleEn}</div>
            </div>
          </div>
          <p class="rule-summary">{r.summaryZh}</p>
          <ul class="rule-points">
            {r.pointsZh.map((p) => {
              const m = p.match(/^\[tip\]\s*(.+)$/);
              return m ? <li class="tip" set:html={m[1]} /> : <li set:html={p} />;
            })}
          </ul>
          {r.tipZh && <div class="rule-tip">💡 {r.tipZh}</div>}
        </article>
      ))}
    </div>
  </main>

  <Footer locale="zh" />

  <script is:inline src="/page.js" defer></script>
</Layout>
