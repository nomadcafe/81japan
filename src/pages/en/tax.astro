---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import tax from '../../data/tax.json';
import '../../styles/page.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      'name': 'Taxes in Japan',
      'itemListElement': tax.map((r, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': r.titleEn,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://www.81japan.com/en' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Taxes' },
      ],
    },
  ],
};
---
<Layout
  title="Taxes · For Salaried Workers in Japan | 81Japan"
  description="Taxes when working in Japan: payroll withholding, resident tax, final filing (kakutei shinkoku), Furusato Nozei, medical deductions — from a salaried-worker perspective."
  path="/en/tax"
  locale="en"
>
  <Fragment slot="head">
    <meta name="keywords" content="Japan tax,kakutei shinkoku,resident tax Japan,furusato nozei,medical deduction Japan,e-Tax,Japan income tax,salaried worker Japan" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="tax" locale="en" />

  <section class="page-hero">
    <div class="eyebrow">Taxes</div>
    <h1>Taxes <em>when working in Japan</em></h1>
    <p>Company employees usually don't file themselves — but resident tax, Furusato Nozei, and medical deductions are worth knowing.</p>
  </section>

  <main class="page-main">
    <div class="rules-grid">
      {tax.map((r) => (
        <article class="rule-card" id={r.id}>
          <div class="rule-card-head">
            <div class="rule-icon" aria-hidden="true">{r.icon}</div>
            <div>
              <div class="rule-title">{r.titleEn}</div>
              <div class="rule-title-en">{r.titleZh}</div>
            </div>
          </div>
          <p class="rule-summary">{r.summaryEn}</p>
          <ul class="rule-points">
            {r.pointsEn.map((p) => <li>{p}</li>)}
          </ul>
          {r.tipEn && <div class="rule-tip">💡 {r.tipEn}</div>}
        </article>
      ))}
    </div>
  </main>

  <Footer locale="en" />

  <script is:inline src="/page.js" defer></script>
</Layout>
