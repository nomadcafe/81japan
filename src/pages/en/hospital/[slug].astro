---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { loadHospitals, hospitalSlug, type Hospital } from '../../../lib/hospitals.js';
import { deptLabel, hospitalName, regionLabel, badgeLabel } from '../../../lib/i18n';
import '../../../styles/page.css';
import '../../../styles/hospital.css';

export async function getStaticPaths() {
  const data = await loadHospitals();
  return data.map((h) => ({
    params: { slug: hospitalSlug(h) },
    props: { hospital: h },
  }));
}

const { hospital: h } = Astro.props as { hospital: Hospital };
const slug = hospitalSlug(h);
const url = `https://www.81japan.com/en/hospital/${encodeURIComponent(slug)}`;
const displayName = hospitalName(h, 'en');

const telDigits = (h.phone || '').replace(/[^\d+]/g, '');
const hasPhone = telDigits.length >= 9;

// English content with fallback to the original (Chinese) value.
const addressEn = h.addressEn || h.address;
const addressShortEn = h.addressShortEn || h.addressShort;
const hoursEn = h.hoursEn || h.hours;
const hoursShortEn = h.hoursShortEn || h.hoursShort;
const closedEn = h.closedEn || h.closed;
const langDetailEn = h.langDetailEn || h.langDetail;
const noteEn = h.noteEn || h.note;
const warningEn = h.warningEn || h.warning;
const phoneEn = h.phoneEn || h.phone;

// Map query keeps the original name/address so Google Maps resolves the real place.
const mapAddr = h.address || h.addressShort;
const mapHref = mapAddr
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(h.name + ' ' + mapAddr)}`
  : null;

const updatedFmt = (() => {
  const m = (h.updated || '').match(/^(\d{4})-(\d{1,2})$/);
  return m ? `${m[1]}-${m[2].padStart(2, '0')}` : (h.updated || '');
})();

const langSet = new Set(h.langs || []);
const isCN = langSet.has('中文');
const isEN = langSet.has('英文');

const langTokens = ((h.langDetail || (h.langs || []).join(' ')).match(/中文|英文|粤语|台语|韩文|俄文/g) || [])
  .filter((v: string, i: number, a: string[]) => a.indexOf(v) === i);

const regionEn = h.region ? regionLabel(h.region, 'en') : 'Japan';

const description = `${displayName}${h.jpName ? ` (${h.jpName})` : ''} in ${regionEn}${addressShortEn ? ', ' + addressShortEn : ''}. ${
  isCN ? 'Chinese-speaking staff available. ' : ''
}${(h.depts && h.depts.length) ? 'Departments include ' + h.depts.slice(0, 4).map((d) => deptLabel(d, 'en')).join(', ') + '. ' : ''}${
  h.phone ? 'Phone: ' + h.phone + '.' : ''
}`.slice(0, 160);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': h.depts && h.depts.length > 1 ? 'Hospital' : 'MedicalOrganization',
      '@id': url + '#organization',
      'name': displayName,
      ...(h.jpName || h.name !== displayName ? { 'alternateName': [h.jpName, h.name !== displayName ? h.name : undefined].filter(Boolean) } : {}),
      'url': url,
      ...(h.phone ? { 'telephone': h.phone } : {}),
      ...(mapAddr ? {
        'address': {
          '@type': 'PostalAddress',
          'streetAddress': addressEn || addressShortEn,
          'addressRegion': regionEn,
          'addressCountry': 'JP',
        },
      } : {}),
      ...(h.depts && h.depts.length ? { 'medicalSpecialty': h.depts } : {}),
      ...(langTokens.length ? {
        'availableLanguage': langTokens.map((l) => {
          const map: Record<string, string> = { '中文': 'zh', '英文': 'en', '粤语': 'yue', '台语': 'nan', '韩文': 'ko', '俄文': 'ru' };
          return map[l] || l;
        }),
      } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Hospitals', 'item': 'https://www.81japan.com/en' },
        { '@type': 'ListItem', 'position': 2, 'name': displayName },
      ],
    },
  ],
};
---
<Layout
  title={`${displayName}${h.jpName && h.jpName !== displayName ? ' (' + h.jpName + ')' : ''} · Chinese-Speaking Hospital in ${regionEn} | 81Japan`}
  description={description}
  path={`/en/hospital/${slug}`}
  locale="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="hospitals" locale="en" />

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/en">Hospitals</a>
    <span class="bc-sep">/</span>
    <span class="bc-current">{regionEn}</span>
    <span class="bc-sep">/</span>
    <span class="bc-current">{displayName}</span>
  </nav>

  <article class="h-detail">
    <header class="h-header">
      <div class="h-eyebrow">
        {h.region && <span class="h-region">{regionEn}</span>}
        <div class="h-badges">
          {isCN && <span class="badge badge-cn">CN</span>}
          {isEN && <span class="badge badge-en">EN</span>}
          {(h.extraBadges || []).map((b) => <span class="badge badge-new">{badgeLabel(b.label, 'en')}</span>)}
        </div>
      </div>
      <h1 class="h-name">{displayName}</h1>
      {h.jpName && h.jpName !== displayName && <p class="h-name-ja">{h.jpName}{h.name !== displayName ? ` · ${h.name}` : ''}</p>}

      <div class="h-cta">
        {hasPhone && (
          <a class="h-cta-btn h-cta-primary" href={`tel:${telDigits}`}>
            <span aria-hidden="true">📞</span>
            <span>Call</span>
          </a>
        )}
        {mapHref && (
          <a class="h-cta-btn" href={mapHref} target="_blank" rel="noopener noreferrer">
            <span aria-hidden="true">🗺</span>
            <span>View on Google Maps</span>
          </a>
        )}
      </div>
    </header>

    <section class="h-section">
      <h2 class="h-section-title">Basics</h2>
      <dl class="h-info-grid">
        {(addressEn || addressShortEn) && (
          <div class="h-info-item">
            <dt>Address</dt>
            <dd>{addressEn || addressShortEn}</dd>
          </div>
        )}
        {h.phone && (
          <div class="h-info-item">
            <dt>Phone</dt>
            <dd>{hasPhone ? <a href={`tel:${telDigits}`}>{phoneEn}</a> : phoneEn}</dd>
          </div>
        )}
        {(hoursEn || hoursShortEn) && (
          <div class="h-info-item">
            <dt>Hours</dt>
            <dd>{hoursEn || hoursShortEn}</dd>
          </div>
        )}
        {closedEn && (
          <div class="h-info-item">
            <dt>Closed</dt>
            <dd>{closedEn}</dd>
          </div>
        )}
      </dl>
    </section>

    {langTokens.length > 0 && (
      <section class="h-section">
        <h2 class="h-section-title">Languages</h2>
        {langDetailEn && <p class="h-lang-detail">{langDetailEn}</p>}
      </section>
    )}

    {h.depts && h.depts.length > 0 && (
      <section class="h-section">
        <h2 class="h-section-title">Departments</h2>
        <div class="h-dept-list">
          {h.depts.map((d) => <span class="dept-tag">{deptLabel(d, 'en')}</span>)}
        </div>
      </section>
    )}

    {noteEn && (
      <section class="h-section">
        <h2 class="h-section-title">Notes</h2>
        <p class="h-note">{noteEn}</p>
      </section>
    )}

    {warningEn && (
      <section class="h-section">
        <div class="h-warning">⚠️ {warningEn}</div>
      </section>
    )}

    <footer class="h-meta">
      <span>Last updated: {updatedFmt}</span>
      <a class="h-back" href="/en">← Back to list</a>
    </footer>
  </article>

  <Footer locale="en" />

  <script is:inline src="/page.js" defer></script>
</Layout>
