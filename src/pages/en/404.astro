---
import Layout from '../../layouts/Layout.astro';
import NavSimple from '../../components/NavSimple.astro';
import '../../styles/submit.css';
---
<Layout
  title="Page not found · 404 | 81Japan"
  description="The page you're looking for doesn't exist. Return to 81Japan to find Chinese-speaking hospitals in Japan."
  path="/en/404.html"
  noindex={true}
  locale="en"
>
  <Fragment slot="head">
    <style is:global>
      .nf-wrap {
        flex: 1;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 80px 24px;
        text-align: center;
      }
      .nf-code {
        font-family: var(--serif);
        font-size: clamp(96px, 18vw, 180px);
        line-height: 1;
        color: var(--red);
        letter-spacing: 0.02em;
        margin-bottom: 16px;
      }
      .nf-title {
        font-family: var(--serif);
        font-size: 28px;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: 12px;
      }
      .nf-desc {
        color: var(--ink-2);
        max-width: 480px;
        margin-bottom: 32px;
      }
      .nf-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
      .nf-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 10px 20px; border-radius: var(--radius-sm);
        font-size: 14px; text-decoration: none;
        transition: all 0.15s;
      }
      .nf-btn-primary { background: var(--red); color: var(--white); }
      .nf-btn-primary:hover { background: #A83224; }
      .nf-btn-ghost { border: 1px solid var(--paper-3); color: var(--ink-2); }
      .nf-btn-ghost:hover { background: var(--paper-2); color: var(--ink); }
    </style>
  </Fragment>

  <NavSimple showLang={false} locale="en" backLabelEn="Home" />

  <main class="nf-wrap">
    <div class="nf-code">404</div>
    <div class="nf-title">Page not found</div>
    <p class="nf-desc">The page you're looking for doesn't exist or was moved. Head back to the home page to find Chinese-speaking hospitals in Japan.</p>
    <div class="nf-actions">
      <a href="/en" class="nf-btn nf-btn-primary">Back to home</a>
      <a href="/en/submit" class="nf-btn nf-btn-ghost">Submit / Correct</a>
    </div>
  </main>
</Layout>
