---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HospitalCard from '../components/HospitalCard.astro';
import { loadHospitals, hospitalSlug } from '../lib/hospitals.js';
import '../styles/index.css';

const hospitals = await loadHospitals();
const total = hospitals.length;

const regionCounts: Record<string, number> = {};
const langCounts: Record<string, number> = { '中文': 0, '英文': 0, '越南语': 0 };
hospitals.forEach((h) => {
  if (h.region) regionCounts[h.region] = (regionCounts[h.region] || 0) + 1;
  (h.langs || []).forEach((l) => {
    if (l in langCounts) langCounts[l]++;
  });
});

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://www.81japan.com/#website',
      'url': 'https://www.81japan.com/',
      'name': '81日本',
      'description': '收录日本全国提供中文医疗服务的医院与诊所信息',
      'inLanguage': ['zh-Hans', 'en'],
      'potentialAction': {
        '@type': 'SearchAction',
        'target': {
          '@type': 'EntryPoint',
          'urlTemplate': 'https://www.81japan.com/?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      '@id': 'https://www.81japan.com/#organization',
      'name': '81日本',
      'url': 'https://www.81japan.com/',
      'description': '在日中文医疗信息',
    },
    {
      '@type': 'ItemList',
      '@id': 'https://www.81japan.com/#hospital-list',
      'name': '在日中文医院列表',
      'numberOfItems': total,
      'itemListElement': hospitals.map((h, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': h.name,
        'url': `https://www.81japan.com/hospital/${encodeURIComponent(hospitalSlug(h))}`,
      })),
    },
  ],
};
---
<Layout
  title="81日本 | 在日中文生活 · 医院・行政・税务指南"
  description="为在日中文使用者整理的医疗、行政、税务、租房指南。首页为中文医院・诊所列表，涵盖东京、横浜、大阪、京都、神户、福冈、名古屋、北海道、广岛、冈山。"
  path="/"
  locale="zh"
>
  <Fragment slot="head">
    <meta name="keywords" content="在日中文医院,日本中文诊所,日本看病,中文医疗,日本华人医院,东京中文医院,大阪中文医院,京都中文医院,在日生活,中文医生" />
    <meta name="author" content="81Japan" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="hospitals" locale="zh" />

  <section class="hero" aria-labelledby="heroTitle">
    <div class="hero-card">
      <div class="hero-eyebrow" id="heroTitle">81日本 · 在日生活中文指南</div>
      <h1 class="visually-hidden">81日本 — 在日中文医院・诊所查询指南</h1>
      <p class="hero-sub">收集了一些提供中文服务的医院、诊所及生活信息，希望能帮到初到日本的你。</p>

      <div class="search-wrap" role="search" aria-label="搜索医院">
        <input class="search-input" placeholder="搜索医院名称、城市、科室…" id="searchInput" oninput="onSearchInput()" />
        <button class="search-btn">搜索</button>
      </div>
      <p class="hero-coverage">覆盖 关东・关西・九州・北海道・中部</p>
    </div>
  </section>

  <div class="main-layout">
    <aside class="sidebar" aria-label="筛选条件">
      <div class="filter-group">
        <div class="filter-title">地区</div>
        <div class="filter-option active" onclick="filterRegion('全部', this)" data-region-filter="全部">
          <span>全部地区</span>
          <span class="filter-count">{total}</span>
        </div>
        {[
          { key: '东京', label: '东京・关东' },
          { key: '埼玉', label: '埼玉' },
          { key: '横浜', label: '横浜・神奈川' },
          { key: '大阪', label: '大阪・关西' },
          { key: '京都', label: '京都・关西' },
          { key: '神户', label: '神户・关西' },
          { key: '福冈', label: '福冈・九州' },
          { key: '札幌', label: '北海道' },
          { key: '名古屋', label: '名古屋・中部' },
          { key: '广岛', label: '广岛・中国' },
          { key: '冈山', label: '冈山・中国' },
          { key: '浜松', label: '浜松・静冈' },
          { key: '仙台', label: '仙台・东北' },
          { key: '冲绳', label: '冲绳' },
        ].filter(r => (regionCounts[r.key] || 0) > 0).map(r => (
          <div class="filter-option" onclick={`filterRegion('${r.key}', this)`} data-region-filter={r.key}>
            <span>{r.label}</span>
            <span class="filter-count">{regionCounts[r.key]}</span>
          </div>
        ))}
      </div>

      <div class="filter-group">
        <div class="filter-title">服务语言</div>
        <div class="filter-option active" onclick="filterLang('全部', this)" data-lang-filter="全部">
          <span>全部</span>
          <span class="filter-count">{total}</span>
        </div>
        <div class="filter-option" onclick="filterLang('中文', this)" data-lang-filter="中文">
          <span>🇨🇳 中文对应</span>
          <span class="filter-count">{langCounts['中文']}</span>
        </div>
        <div class="filter-option" onclick="filterLang('英文', this)" data-lang-filter="英文">
          <span>🇺🇸 英文对应</span>
          <span class="filter-count">{langCounts['英文']}</span>
        </div>
        <div class="filter-option" onclick="filterLang('越南语', this)" data-lang-filter="越南语">
          <span>🇻🇳 越南语对应</span>
          <span class="filter-count">{langCounts['越南语']}</span>
        </div>
      </div>

      <div class="filter-group">
        <div class="filter-title">科室</div>
        <div class="filter-option" onclick="setSearch('内科')">内科</div>
        <div class="filter-option" onclick="setSearch('外科')">外科</div>
        <div class="filter-option" onclick="setSearch('产科')">产科・妇科</div>
        <div class="filter-option" onclick="setSearch('儿科')">儿科</div>
        <div class="filter-option" onclick="setSearch('皮肤科')">皮肤科</div>
        <div class="filter-option" onclick="setSearch('精神科')">精神科・心理</div>
        <div class="filter-option" onclick="setSearch('牙科')">牙科・口腔</div>
      </div>
    </aside>

    <main>
      <div class="list-header">
        <div class="list-title">共找到 <strong id="shownCount">{total}</strong> 家医疗机构</div>
        <select class="sort-select" id="sortSelect" onchange="sortCards(this.value)">
          <option value="date">最近更新</option>
          <option value="region">按地区</option>
          <option value="dept">按科室</option>
        </select>
      </div>

      <div id="cardList" role="list" aria-label="医院列表">
        {hospitals.map((h) => <HospitalCard hospital={h} locale="zh" />)}
      </div>

      <div id="emptyState" style="display:none; text-align:center; padding:60px 20px; color:var(--ink-3);">
        <div style="font-size:32px; margin-bottom:12px;">🔍</div>
        <div style="font-size:15px; margin-bottom:6px;">没有找到相关结果</div>
        <div style="font-size:13px;">换个关键词试试，或者 <a href="/submit" style="color:var(--red);">提交新信息</a></div>
      </div>
    </main>
  </div>

  <section class="submit-section" id="submit">
    <div class="submit-banner">
      <div class="submit-banner-text">
        <h2>知道遗漏的<em>信息？</em></h2>
        <p>如果你知道某家医院提供中文服务，或发现信息有误，欢迎投稿——我会人工审核后更新。</p>
      </div>
      <a href="/submit" class="submit-banner-btn">前往投稿 →</a>
    </div>
  </section>

  <Footer locale="zh" />

  <script is:inline src="/hospitals.js" defer></script>
</Layout>
