---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import rules from '../data/rules.json';
import '../styles/page.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      'name': '日本生活ルール',
      'itemListElement': rules.map((r, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': r.titleZh,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': '首页', 'item': 'https://www.81japan.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': '日本ルール' },
      ],
    },
  ],
};
---
<Layout
  title="日本ルール · 在日生活规矩速查 | 81日本"
  description="初到日本最容易踩坑的文化与社会礼仪：电车・电梯礼仪、食べ歩き 等。"
  path="/rules"
  locale="zh"
>
  <Fragment slot="head">
    <meta name="keywords" content="日本生活规则,日本电车礼仪,电梯礼仪,食べ歩き,公共交通礼仪,日本生活指南" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="rules" locale="zh" />

  <section class="page-hero">
    <div class="eyebrow">日本ルール</div>
    <h1>初到日本，先记<em>这些规矩</em></h1>
    <p>日本社会里不成文但人人遵守的礼仪。</p>
  </section>

  <main class="page-main">
    <div class="rules-grid">
      {rules.map((r) => (
        <article class="rule-card" id={r.id}>
          <div class="rule-card-head">
            <div class="rule-icon" aria-hidden="true">{r.icon}</div>
            <div>
              <div class="rule-title">{r.titleZh}</div>
              <div class="rule-title-en">{r.titleEn}</div>
            </div>
          </div>
          <p class="rule-summary">{r.summaryZh}</p>
          <ul class="rule-points">
            {r.pointsZh.map((p) => <li>{p}</li>)}
          </ul>
          {r.tipZh && <div class="rule-tip">💡 {r.tipZh}</div>}
        </article>
      ))}
    </div>
  </main>

  <Footer locale="zh" />

  <script is:inline src="/page.js" defer></script>
</Layout>
