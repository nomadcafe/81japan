---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import admin from '../data/admin.json';
import '../styles/page.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ItemList',
      'name': '在日行政手续指南',
      'itemListElement': admin.map((r, i) => ({
        '@type': 'ListItem',
        'position': i + 1,
        'name': r.titleZh,
      })),
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': '首页', 'item': 'https://www.81japan.com/' },
        { '@type': 'ListItem', 'position': 2, 'name': '行政手续' },
      ],
    },
  ],
};
---
<Layout
  title="行政手续 · 在日必办手续速查 | 81日本"
  description="初到日本最关键的行政手续：住民票、在留卡、マイナンバー、国民健康保险、银行开户——按办理顺序整理。"
  path="/admin"
  locale="zh"
>
  <Fragment slot="head">
    <meta name="keywords" content="日本行政手续,住民票,在留卡,マイナンバー,国民健康保险,日本银行开户,在日生活指南" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="admin" locale="zh" />

  <section class="page-hero">
    <div class="eyebrow">行政手续</div>
    <h1>来日本，先把<em>这些手续办了</em></h1>
  </section>

  <main class="page-main">
    <div class="rules-grid">
      {admin.map((r) => (
        <article class="rule-card" id={r.id}>
          <div class="rule-card-head">
            <div class="rule-icon" aria-hidden="true">{r.icon}</div>
            <div>
              <div class="rule-title">{r.titleZh}</div>
              <div class="rule-title-en">{r.titleEn}</div>
            </div>
          </div>
          <p class="rule-summary">{r.summaryZh}</p>
          <ul class="rule-points">
            {r.pointsZh.map((p) => {
              const m = p.match(/^\[tip\]\s*(.+)$/);
              return m ? <li class="tip" set:html={m[1]} /> : <li set:html={p} />;
            })}
          </ul>
          {r.tipZh && <div class="rule-tip">💡 {r.tipZh}</div>}
        </article>
      ))}
    </div>
  </main>

  <Footer locale="zh" />

  <script is:inline src="/page.js" defer></script>
</Layout>
