---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/page.css';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  'name': '关于 81日本',
  'url': 'https://www.81japan.com/about',
  'description': '81日本是一个由社区共同维护的在日中文生活信息平台。',
};
---
<Layout
  title="关于我们 · 81日本 | 在日中文生活信息平台"
  description="81日本是由社区共同维护的非营利信息平台，专注于为在日中文使用者整理医疗、行政、生活等实用信息。"
  path="/about"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Nav active="about" />

  <section class="page-hero">
    <div class="eyebrow">
      <span class="zh-only">关于 81Japan</span>
      <span class="en-only">About</span>
    </div>
    <h1 class="zh-only">和 81Japan 一起，在日生活 <em>少走点弯路</em></h1>
    <h1 class="en-only">Making life in Japan <em>a little easier</em></h1>
    <p class="zh-only">81日本是一个由社区共同维护的非营利信息平台，专注于为在日中文使用者整理医疗、行政、生活等实用信息。</p>
    <p class="en-only">81Japan is a community-maintained, non-profit directory for Chinese-speaking residents — covering healthcare, paperwork, and everyday life in Japan.</p>
  </section>

  <main class="page-main">
    <div class="about-body">

      <div class="zh-only">
        <h2>站上有什么</h2>
        <ul>
          <li><a href="/">医院诊所</a>——日本各地能用中文看病的医院和诊所</li>
          <li><a href="/rules">日本ルール</a>——刚到日本最容易踩坑的生活规则</li>
          <li>行政手续 / 生活服务——在做，欢迎一起补</li>
        </ul>

        <h2>信息怎么来的</h2>
        <p>每条医院信息我们都会核一下：医院官网、厚生劳动省的公开资料，或社区投稿后再查证一遍。每张卡片都标了最近更新日期。但医院情况会变，看病前最好先打个电话确认。发现写错了，<a href="/submit">告诉我们</a>就好。</p>

        <h2>找到我们</h2>
        <p>有医院要补、信息要纠、合作想聊、单纯吐槽——<a href="/submit">欢迎联系</a>。</p>
      </div>

      <div class="en-only">
        <h2>What's here</h2>
        <ul>
          <li><a href="/">Hospitals & Clinics</a> — places across Japan where you can be seen in Chinese</li>
          <li><a href="/rules">Living in Japan</a> — the everyday rules newcomers most often trip on</li>
          <li>Admin / Life services — in progress; contributions welcome</li>
        </ul>

        <h2>Where the info comes from</h2>
        <p>Every hospital entry is checked against an official source — the hospital's own site, MHLW notices, or community submissions we follow up on. Each card shows its last-updated date. Things change, though — please call ahead before visiting. Spot something wrong? <a href="/submit">Let us know</a>.</p>

        <h2>Reach us</h2>
        <p>Hospitals to add, info to correct, partnership ideas, or just feedback — drop it in the <a href="/submit">submission page</a>. It lands straight in our Telegram, and we read it.</p>
      </div>

      <div class="about-cta">
        <div class="cta-text">
          <span class="zh-only">发现漏掉的医院，或有想补充的内容？<br><strong>投稿直达维护者。</strong></span>
          <span class="en-only">Know a hospital we missed, or want to add something?<br><strong>Submissions reach us directly.</strong></span>
        </div>
        <a href="/submit">
          <span class="zh-only">前往投稿 →</span>
          <span class="en-only">Contribute →</span>
        </a>
      </div>

    </div>
  </main>

  <Footer />

  <script is:inline src="/page.js" defer></script>
</Layout>
